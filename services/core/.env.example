# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview
MODEL_CONTEXT_WINDOW=128000

# LangSmith (optional - for tracing and debugging)
# LANGSMITH_API_KEY=your-langsmith-key
# LANGSMITH_TRACING=true

# PostgreSQL Configuration (for main_postgres.py)
# Option 1: Full connection string (recommended)
POSTGRES_URI=postgresql://user:password@localhost:5432/garuda_checkpoints

# Option 2: Individual components (if POSTGRES_URI not set)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=garuda_checkpoints
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password
